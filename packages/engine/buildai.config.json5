{
  "browser": {
    "enabled": false
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-6"
      },
      "workspace": "../../workspaces/buildai-agent",
      "thinkingDefault": "off",
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    },
    "list": [
      {
        "id": "sarah-pm-agent",
        "name": "Sarah PM Agent",
        "workspace": "../../workspaces/sarah-pm-agent",
        "model": {
          "primary": "anthropic/claude-sonnet-4-6"
        },
        "identity": {
          "name": "BuildAI",
          "emoji": "\ud83c\udfd7\ufe0f"
        }
      },
      {
        "id": "jarvis2",
        "name": "Jarvis2",
        "workspace": "../../workspaces/jarvis2",
        "model": {
          "primary": "anthropic/claude-sonnet-4-20250514"
        },
        "identity": {
          "name": "BuildAI",
          "emoji": "\ud83c\udfd7\ufe0f"
        },
        "heartbeat": {
          "every": "30m",
          "activeHours": {
            "start": "07:00",
            "end": "19:00"
          },
          "prompt": "Read HEARTBEAT.md. Run the monitoring checks using available skills. If any issues found, write alerts to ACTIVE.md. If nothing needs attention, reply HEARTBEAT_OK."
        }
      }
    ]
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  },
  "cron": {
    "enabled": true
  },
  "hooks": {
    "internal": {
      "enabled": true
    }
  },
  "channels": {
    "telegram": {
      "enabled": false
    },
    "discord": {
      "enabled": false
    },
    "whatsapp": {
      "enabled": false
    },
    "slack": {
      "enabled": false
    },
    "signal": {
      "enabled": false
    },
    "imessage": {
      "enabled": false
    },
    "line": {
      "enabled": false
    },
    "googlechat": {
      "enabled": false
    },
    "msteams": {
      "enabled": false
    }
  },
  "canvasHost": {
    "enabled": false
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "none"
    },
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:3000",
        "http://127.0.0.1:3000"
      ],
      "dangerouslyDisableDeviceAuth": true
    },
    "mdns": false
  },
  "skills": {
    "allowBundled": [
      "buildai-database",
      "buildai-procore",
      "buildai-monitor",
      "buildai-marketplace",
      "buildai-pdf-extract",
      "buildai-doc-generator",
      "buildai-invoice-parser",
      "buildai-contract-parser",
      "buildai-schedule-import",
      "buildai-safety-checker",
      "buildai-photo-log",
      "buildai-email",
      "buildai-excel-export"
    ]
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      }
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "meta": {
    "lastTouchedVersion": "2026.1.24-3",
    "lastTouchedAt": "2026-02-17T10:32:00.198Z"
  }
}